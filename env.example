# Copie este arquivo para .env e preencha os valores.
#
# Acesso ao botao Admin (Sobre): o site chama POST /api/admin/local-login.
# Rode o site com: npm install && npm start  e abra http://localhost:3000/
# Se a porta 3000 estiver com OUTRO programa: npm run start:3010  e abra http://localhost:3010/
# Abrir o index.html direto no disco (file://) nao funciona para essa etapa.
# O servidor forca este .env a prevalecer sobre variaveis vazias do ambiente (ex.: Cursor).

# URL publica do seu site (exemplo: https://portal.exemplo.com)
APP_ORIGIN=

# URL exata do site nas meta Open Graph (WhatsApp / Facebook). Opcional: se vazio,
# o server.js em GET / usa o Host da requisicao. Em deploy so-estatico (sem Node),
# ajuste og:url e og:image no index.html para o seu dominio.
# Tambem define a origem em /sitemap.xml e /robots.txt na Vercel (api/sitemap + api/robots).
PORTAL_PUBLIC_ORIGIN=

# --- Google / indexacao ---
# 1) Apos deploy: abra https://SEU-DOMINIO/robots.txt e https://SEU-DOMINIO/sitemap.xml
# 2) Google Search Console (search.google.com/search-console) → Adicionar propriedade (URL ou prefixo)
# 3) Verificacao de dominio (DNS ou ficheiro HTML) → Sitemaps → envie: https://SEU-DOMINIO/sitemap.xml
# Com dominio proprio, defina PORTAL_PUBLIC_ORIGIN=https://seudominio.com na Vercel e redeploy.
# Na Vercel, mantenha ligado "Expor automaticamente variaveis de ambiente do sistema"
# (usa VERCEL_PROJECT_PRODUCTION_URL no sitemap/robots em vez do URL efemero do deploy).

# Google Search Console — verificacao por etiqueta HTML (recomendado na Vercel):
# No GSC escolha "Etiqueta HTML", copie SOMENTE o valor do content= (ex.: AbCdEf...xyz).
# Crie GOOGLE_SITE_VERIFICATION na Vercel com esse valor, redeploy, verifique de novo.
# Metodo "ficheiro HTML": coloque o ficheiro descarregado (nome exato google....html)
# na raiz do repositorio junto ao index.html, commit + push (o deploy serve como ficheiro estatico).

# Atras de Nginx/reverse proxy (rate limit / IP): numero de proxies na frente do Node
# TRUST_PROXY_HOPS=1

# Protecao extra antes da Area Admin: so a senha abre o primeiro passo (NUNCA use valor fraco)
# ADMIN_LOCAL_USER ficou obsoleto; use apenas ADMIN_LOCAL_PASS.
# Com @, # ou espacos, use aspas duplas (uma linha so — duplicar com linha vazia apaga a senha em alguns editores):
# ADMIN_LOCAL_PASS="AGENDA@2026"
ADMIN_LOCAL_PASS=

# Opcional: ajuste de rate limit do Acesso Local
# ADMIN_LOCAL_WINDOW_MS=600000
# ADMIN_LOCAL_MAX_ATTEMPTS=5
# Senha local antes do Supabase: em Vercel o padrao e true (pula modal). false = exige modal
# (precisa ADMIN_LOCAL_PASS nas env vars da Vercel). Local (npm start) padrao false = pede senha .env.
# PORTAL_SKIP_LOCAL_ADMIN_GATE=false
#
# Vercel: copie SUPABASE_* e as PORTAL_* que quiser. ADMIN_LOCAL_PASS e opcional — se vazio,
# o site no ar nao pede o primeiro modal (so login Supabase). Se preencher, crie a mesma
# variavel no painel Vercel para ativar o modal + POST /api/admin/local-login.
# Se abrir o HTML como file:// e o Node estiver noutra porta (ex. 3010):
# PORTAL_LOCAL_LOGIN_ORIGIN=http://localhost:3010

# --- Portal comercial (gera /portal-config.js; nao commite chaves no HTML) ---
# As chaves Supabase deixaram de ficar no index.html: copie URL e anon key para SUPABASE_* abaixo.
# Hospedagem so-estatica: copie portal-config.example.js para portal-config.js (veja .gitignore).
PORTAL_SITE_NAME=Portal
# Favicon da aba: substitua o arquivo assets/portal-favicon.jpeg pela sua foto (JPEG, ideal quadrada).
PORTAL_SITE_DESCRIPTION=Guia local com empresas, contatos uteis e utilidades.
PORTAL_REGION_KICKER=Itirapina e regiao
PORTAL_HERO_TITLE=Tudo da cidade em um portal so
PORTAL_HERO_LEAD=Encontre empresas, contatos uteis e horarios de onibus com busca rapida e acesso direto.
PORTAL_CLIMATE_TITLE=Previsao do tempo
# Coordenadas Open-Meteo (ex.: Itirapina SP)
PORTAL_CLIMATE_LAT=-22.2528
PORTAL_CLIMATE_LON=-47.8169
# PORTAL_SOBRE_TITULO=
PORTAL_SOBRE_TEXTO=Guia local com empresas, contatos uteis, horarios de onibus e previsao do tempo. Use o botao Anuncie para falar com quem opera o portal.
# WhatsApp comercial (somente digitos, com DDI 55). Ex.: 5519971689501 = (19) 97168-9501
PORTAL_WHATSAPP_E164=5519971689501
# Placeholder {portal} vira o nome do site (PORTAL_SITE_NAME) no link do botao Anuncie
PORTAL_WHATSAPP_ANUNCIE_MESSAGE=Ola! Vim pelo portal {portal} e tenho interesse em anunciar. Poderia me enviar opcoes e valores?
# Placeholders: {nome} {portal} {data}
PORTAL_WHATSAPP_CLIENT_TEMPLATE=Ola {nome}, vi seu anuncio no {portal} e gostaria de mais informacoes.
PORTAL_WHATSAPP_RENEWAL_TEMPLATE=Ola {nome}! A assinatura do anuncio no {portal} esta proxima do vencimento ({data}). Podemos renovar?
# Prefixo do localStorage (troque por cliente para nao misturar dados)
PORTAL_STORAGE_PREFIX=portal_local
# Supabase (chave anon + RLS no projeto)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_TABLE=empresas
# Admin na nuvem: (1) Supabase → Authentication → Users → Add user (e-mail + senha do operador)
# (2) SQL Editor → rode o arquivo supabase-setup-admin-empresas.sql (RLS + coluna descricao)
#     Opcional: supabase-adicionar-ativo-ate.sql (prazo de visibilidade no admin: 7/15/30/60 dias)
# (3) Sem SUPABASE_*: apos senha local, cadastro fica so no navegador (localStorage)
# URL publica do bucket de logos (sem barra no final), ou vazio para usar /assets
SUPABASE_LOGOS_PUBLIC_BASE=
# true = com Supabase, completa o guia com entradas de data/empresas-demo.json que ainda
# nao existem na tabela (evita aparecer so ~10 cards se o banco estiver incompleto). false = so o banco.
PORTAL_APPLY_DEFAULT_CATALOG=true

# Automacao de RLS no Supabase (scripts externos; preencha se usar)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
# Opcional: restringe INSERT a emails administrativos
SUPABASE_ADMIN_EMAILS=

# --- Vercel (deploy estatico + funcao serverless) ---
# No painel Vercel -> Settings -> Environment Variables, copie as mesmas chaves
# que usa no .env local (minimo: SUPABASE_URL, SUPABASE_ANON_KEY).
# O ficheiro vercel.json reescreve /portal-config.js -> /api/portal-config
# para gerar o script com essas variaveis (admin Supabase + cards no ar).
# Diagnostico (sem expor chaves): GET /api/admin/self-check → supabaseEmAmbiente
# deve ser true depois de definir SUPABASE_* e redeploy.
# GET /api/portal-config-data — mesmo JSON que alimenta o portal (cache no-store no browser).
# Opcional: PORTAL_* e PORTAL_WHATSAPP_* para branding e Anuncie.
